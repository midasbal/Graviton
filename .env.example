# ==============================================
# Graviton — Environment Configuration
# ==============================================

# Wallet private key (WITH 0x prefix)
PRIVATE_KEY=0xyour_private_key_here

# Network: "testnet" or "mainnet"
NETWORK=testnet

# 0G Storage mode: "turbo" or "standard"
STORAGE_MODE=turbo

# 0G Chain RPC URLs (auto-selected by NETWORK, override here if needed)
# RPC_URL_TESTNET=https://evmrpc-testnet.0g.ai
# RPC_URL_MAINNET=https://evmrpc.0g.ai

# Deployed contract addresses (fill in after running deploy script)
GRAVITON_INFT_ADDRESS=
GRAVITON_MARKETPLACE_ADDRESS=
GRAVITON_REGISTRY_ADDRESS=

# Block Explorer API key (optional, for contract verification)
EXPLORER_API_KEY=
