# ==============================================================
#  Graviton .gitignore — Security-hardened for hackathon repo
# ==============================================================

# ── Dependencies ──
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment & Secrets (CRITICAL — never commit) ──
# Covers root AND all subdirectories (e.g. contracts/.env)
.env
.env.*
!.env.example
!contracts/.env.example
*.key
*.pem
*.p12
*.secret

# ── Next.js ──
/.next/
/out/
/build

# ── Hardhat / Solidity ──
contracts/artifacts/
contracts/cache/
contracts/typechain-types/

# ── Testing ──
/coverage

# ── OS / Editor ──
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/settings.json

# ── Debug logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Vercel ──
.vercel

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── AI assistant context files ──
AGENTS.md
CLAUDE.md
0g-rules.md
